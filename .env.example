APP_ENV=local
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=postgresql+psycopg://docsflow:docsflow@db:5432/docsflow
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_RATE_LIMIT_REQUESTS=10
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
LOCAL_STORAGE_PATH=storage

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false

DOCUMENT_PROCESSING_SOFT_TIME_LIMIT_SECONDS=60
DOCUMENT_PROCESSING_HARD_TIME_LIMIT_SECONDS=90
DOCUMENT_PROCESSING_MAX_RETRIES=3
DOCUMENT_PROCESSING_RETRY_DELAY_SECONDS=10